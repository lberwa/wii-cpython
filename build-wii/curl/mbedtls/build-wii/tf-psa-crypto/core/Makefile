	cd /opt/devkitpro/extras/cpython/3.15.0a7/build-wii/curl/mbedtls/build-wii && $(MAKE) $(MAKESILENT) -f tf-psa-crypto/core/CMakeFiles/tfpsacrypto.dir/build.make tf-psa-crypto/core/CMakeFiles/tfpsacrypto.dir/tf_psa_crypto_version.c.i
.PHONY : tf_psa_crypto_version.c.i

tf_psa_crypto_version.s: tf_psa_crypto_version.c.s
.PHONY : tf_psa_crypto_version.s

# target to generate assembly for a file
tf_psa_crypto_version.c.s:
	cd /opt/devkitpro/extras/cpython/3.15.0a7/build-wii/curl/mbedtls/build-wii && $(MAKE) $(MAKESILENT) -f tf-psa-crypto/core/CMakeFiles/tfpsacrypto.dir/build.make tf-psa-crypto/core/CMakeFiles/tfpsacrypto.dir/tf_psa_crypto_version.c.s
.PHONY : tf_psa_crypto_version.c.s

