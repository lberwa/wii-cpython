prefix=/opt/devkitpro/extras/cpython/3.15.0a7/build-wii/curl/mbedtls/install-wii
includedir=${prefix}/include
libdir=${prefix}/lib

Name: TF-PSA-Crypto
Description: TF-PSA-Crypto is a C library that implements cryptographic primitives. Its small code footprint makes it suitable for embedded systems.
URL: https://www.trustedfirmware.org/projects/mbed-tls/
Version: 1.0.0
Cflags: -I"${includedir}"
Libs: -L"${libdir}" -ltfpsacrypto
