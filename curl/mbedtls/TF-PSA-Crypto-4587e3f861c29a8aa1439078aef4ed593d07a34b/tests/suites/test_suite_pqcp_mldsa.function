/* BEGIN_HEADER */

/* Basic tests for the mldsa-native from the pqcp driver.
 * We generally assume that mldsa-native is functionally correct.
 * The objective of this test suite is to validate that it's configured
 * and built as intended. */

#include <wrap_mldsa_native.h>

/* END_HEADER */

/* BEGIN_DEPENDENCIES
 * depends_on:TF_PSA_CRYPTO_PQCP_MLDSA_ENABLED:MBEDTLS_PSA_CRYPTO_C
 * END_DEPENDENCIES */

/* BEGIN_CASE depends_on:TF_PSA_CRYPTO_PQCP_MLDSA_87_ENABLED */
void smoke_87(data_t *seed)
{
    uint8_t *secret_key = NULL;
    const size_t secret_key_length = MLDSA_SECRETKEYBYTES(87);
    uint8_t *public_key = NULL;
    const size_t public_key_length = MLDSA_PUBLICKEYBYTES(87);
    const uint8_t prefix[2] = { 0, 0 }; // pure ML-DSA with empty context
    const size_t prefix_length = sizeof(prefix);
    const uint8_t rnd[MLDSA_RNDBYTES] = { 0 };
    uint8_t *signature = NULL;
    const size_t signature_size = MLDSA_BYTES(87);
    size_t signature_length = SIZE_MAX;
    uint8_t message[14] MBEDTLS_ATTRIBUTE_UNTERMINATED_STRING = "This is a test";
    const size_t message_length = sizeof(message);

    /* Sanity checks on the test data */
    TEST_EQUAL(seed->len, MLDSA_SEEDBYTES);

    TEST_CALLOC(secret_key, secret_key_length);
    TEST_CALLOC(public_key, public_key_length);
    TEST_CALLOC(signature, signature_size);

    /* Calculate the expanded key pair from the seed */
    TEST_EQUAL(tf_psa_crypto_pqcp_mldsa87_keypair_internal(
                   public_key, secret_key,
                   seed->x), 0);

    /* Calculate a deterministic signature */
    TEST_EQUAL(tf_psa_crypto_pqcp_mldsa87_signature_internal(
                   signature, &signature_length,
                   message, message_length,
                   prefix, prefix_length, rnd, secret_key, 0), 0);
    TEST_EQUAL(signature_length, MLDSA_BYTES(87));

    /* Verify the signature */
    TEST_EQUAL(tf_psa_crypto_pqcp_mldsa87_verify(
                   signature, signature_length,
                   message, message_length,
                   NULL, 0, public_key), 0);

exit:
    mbedtls_free(secret_key);
    mbedtls_free(public_key);
    mbedtls_free(signature);
}
/* END_CASE */
