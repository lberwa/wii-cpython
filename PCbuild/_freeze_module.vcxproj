      <Clean Include="%(None.IntFile)" />
      <Clean Include="%(None.OutFile)" />
      <Clean Include="%(GetPath.IntFile)" />
      <Clean Include="%(GetPath.OutFile)" />
      <Clean Include="$(GeneratedFrozenModulesDir)deepfreeze.c" />
    </ItemGroup>
  </Target>
